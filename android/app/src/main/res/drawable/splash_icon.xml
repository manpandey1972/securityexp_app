<?xml version="1.0" encoding="utf-8"?>
<!--
    Invisible icon for the Android 12+ system splash. The platform
    requires *some* drawable in `windowSplashScreenAnimatedIcon`; this
    one is just a solid shape painted the same color as the splash
    background, so the system splash blends seamlessly into the
    Flutter "Welcome to GreenHive" screen.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/splash_background" />
</shape>
